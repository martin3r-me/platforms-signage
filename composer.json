{
  "name": "martin3r/platforms-signage",
  "description": "Digital Signage Module for Platform - Upload media, build playlists and display them on TVs/monitors",
  "type": "library",
  "autoload": {
    "psr-4": {
      "Platform\\Signage\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Platform\\Signage\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0"
  },
  "scripts": {
    "test": "phpunit"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Platform\\Signage\\SignageServiceProvider"
      ]
    }
  }
}
